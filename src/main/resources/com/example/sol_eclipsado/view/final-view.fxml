<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sol_eclipsado.controller.FinalController">
   <children>
      <Label fx:id="lbGameResult" text="RESULTADO DE LA PARTIDA">
         <font>
            <Font name="Tahoma Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" top="35.0" />
         </VBox.margin>
      </Label>
      <ImageView fitHeight="300.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
         <VBox.margin>
            <Insets bottom="30.0" />
         </VBox.margin>
      </ImageView>
      <Label fx:id="lbFinalText" text="Texto segun la partida">
         <font>
            <Font name="Tahoma Bold" size="16.0" />
         </font>
      </Label>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="80.0">
         <children>
            <Button fx:id="btReplay" mnemonicParsing="false" onAction="#onActionReplay" style="-fx-background-color: #5ED65E; -fx-border-color: #1F382A; -fx-border-radius: 5;" text="Volver a jugar">
               <font>
                  <Font name="Tahoma Bold" size="14.0" />
               </font>
            </Button>
            <Button fx:id="btExitGame" mnemonicParsing="false" onAction="#onActionExitGame" style="-fx-background-color: #FF7A7A; -fx-border-width: 1; -fx-border-color: #1F382A; -fx-border-radius: 5;" text="Salir del juego">
               <font>
                  <Font name="Tahoma Bold" size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
